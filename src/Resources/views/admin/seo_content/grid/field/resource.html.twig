{% if data.type == constant('Dedi\\SyliusSEOPlugin\\SEO\\Enum\\MetadataTypeEnum::PRODUCT').value %}
    <a href="{{ path('sylius_admin_product_update', {id: data.product.id}) }}">{{ data.product.name }}</a>
{% elseif data.type == constant('Dedi\\SyliusSEOPlugin\\SEO\\Enum\\MetadataTypeEnum::TAXON').value %}
    <a href="{{ path('sylius_admin_taxon_update', { 'id': data.taxon.id }) }}">{{ data.taxon.fullName }}</a>
{% elseif data.type == constant('Dedi\\SyliusSEOPlugin\\SEO\\Enum\\MetadataTypeEnum::CHANNEL').value %}
    <a href="{{ path('sylius_admin_channel_update', { 'id': data.channel.id }) }}">{{ data.channel.name }}</a>
{% elseif data.type == constant('Dedi\\SyliusSEOPlugin\\SEO\\Enum\\MetadataTypeEnum::URI').value %}
    <a href="{{ data.translation.uri }}" target="_blank">{{ data.translation.uri }}</a>
{% endif %}