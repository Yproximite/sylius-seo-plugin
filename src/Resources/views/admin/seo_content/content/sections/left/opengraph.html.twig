{% import '@SyliusAdmin/shared/helper/translations.html.twig' as translations %}

{% set form = hookable_metadata.context.form %}
{% set prefixes = hookable_metadata.prefixes %}

<div class="card mb-3">
    <div class="card-header">
        <h2 class="card-title">
            OpenGraph
            <small>
                <a target="_blank" href="https://ogp.me/">{{ 'dedi_sylius_seo_plugin.ui.open_graph_info'|trans }}</a>
            </small>
        </h2>
    </div>
    <div class="card-body">
        {% hook 'opengraph.general' %}
    </div>
    <div class="">
        {{ translations.with_hook(form.translations, prefixes, 'opengraph.translations', { accordion_id: 'seo-content-opengraph', accordion_flush: true }) }}
    </div>
</div>
