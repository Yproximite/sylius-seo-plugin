<?xml version="1.0" ?>
<resources xmlns="https://api-platform.com/schema/metadata"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="https://api-platform.com/schema/metadata https://api-platform.com/schema/metadata/metadata-2.0.xsd"
>
    <resource class="%dedi_sylius_seo_plugin.model.seo_content.class%" shortName="SEOContent">

        <attribute name="validation_groups">sylius</attribute>

        <collectionOperations>
            <collectionOperation name="shop_get">
                <attribute name="method">GET</attribute>
                <attribute name="path">/shop/seo-contents</attribute>
                <attribute name="filters">
                    <attribute>dedi_sylius_seo_plugin.api.filter.uri</attribute>
                    <attribute>dedi_sylius_seo_plugin.api.filter.product_code</attribute>
                    <attribute>dedi_sylius_seo_plugin.api.filter.taxon_code</attribute>
                    <attribute>dedi_sylius_seo_plugin.api.filter.channel_code</attribute>
                </attribute>
                <attribute name="normalization_context">
                    <attribute name="groups">shop:seo_content:read</attribute>
                </attribute>
            </collectionOperation>

            <collectionOperation name="admin_post">
                <attribute name="method">POST</attribute>
                <attribute name="path">/admin/seo-contents</attribute>
                <attribute name="denormalization_context">
                    <attribute name="groups">admin:seo_content:create</attribute>
                </attribute>
            </collectionOperation>
        </collectionOperations>

        <itemOperations>
            <itemOperation name="admin_get">
                <attribute name="method">GET</attribute>
                <attribute name="path">/admin/seo-contents/{id}</attribute>
                <attribute name="openapi_context">
                    <attribute name="summary">Retrieves a SEO content resource.</attribute>
                </attribute>
                <attribute name="normalization_context">
                    <attribute name="groups">admin:seo_content:read</attribute>
                </attribute>
            </itemOperation>

            <itemOperation name="shop_get">
                <attribute name="method">GET</attribute>
                <attribute name="path">/shop/seo-contents/{id}</attribute>
                <attribute name="normalization_context">
                    <attribute name="groups">shop:seo_content:read</attribute>
                </attribute>
            </itemOperation>

            <itemOperation name="shop_get_product_metadata">
                <attribute name="method">GET</attribute>
                <attribute name="path">/shop/seo-contents-for-product/{id}</attribute>
                <attribute name="controller">dedi_sylius_seo_plugin.api.controller.product_metadata</attribute>
                <attribute name="read">false</attribute>
                <attribute name="openapi_context">
                    <attribute name="summary">Retrieve a product hierarchical metadata.</attribute>
                    <attribute name="parameters">
                        <attribute>
                            <attribute name="name">uri</attribute>
                            <attribute name="in">query</attribute>
                            <attribute name="required">false</attribute>
                            <attribute name="schema">
                                <attribute name="type">string</attribute>
                            </attribute>
                        </attribute>
                    </attribute>
                </attribute>
                <attribute name="normalization_context">
                    <attribute name="groups">shop:seo_content:read</attribute>
                </attribute>
            </itemOperation>

            <itemOperation name="shop_get_taxon_metadata">
                <attribute name="method">GET</attribute>
                <attribute name="path">/shop/seo-contents-for-taxon/{id}</attribute>
                <attribute name="controller">dedi_sylius_seo_plugin.api.controller.taxon_metadata</attribute>
                <attribute name="read">false</attribute>
                <attribute name="openapi_context">
                    <attribute name="summary">Retrieve a taxon hierarchical metadata.</attribute>
                </attribute>
                <attribute name="normalization_context">
                    <attribute name="groups">shop:seo_content:read</attribute>
                </attribute>
            </itemOperation>

            <itemOperation name="admin_put">
                <attribute name="method">PUT</attribute>
                <attribute name="path">/admin/seo-contents/{id}</attribute>
                <attribute name="denormalization_context">
                    <attribute name="groups">admin:seo_content:update</attribute>
                </attribute>
            </itemOperation>

            <itemOperation name="admin_delete">
                <attribute name="method">DELETE</attribute>
                <attribute name="path">/admin/seo-contents/{id}</attribute>
            </itemOperation>
        </itemOperations>

        <property name="id" identifier="true" writable="false" required="true"/>
        <property name="product" identifier="false" required="false"  writable="true">
            <attribute name="openapi_context">
                <attribute name="type">string</attribute>
                <attribute name="example">/api/v2/shop/products/Everyday_white_basic_T_Shirt</attribute>
            </attribute>
        </property>
        <property name="taxon" identifier="false" required="false" writable="true">
            <attribute name="openapi_context">
                <attribute name="type">string</attribute>
                <attribute name="example">/api/v2/shop/products/caps</attribute>
            </attribute>
        </property>
        <property name="channel" identifier="false" required="false" writable="true">
            <attribute name="openapi_context">
                <attribute name="type">string</attribute>
                <attribute name="example">/api/v2/shop/channels/FASHION_WEB</attribute>
            </attribute>
        </property>
        <property name="robots" identifier="false" required="false" writable="true" readable="true"/>
        <property name="type" identifier="false" required="false" writable="false"/>
        <property name="translations" writable="true" readable="true">
            <attribute name="openapi_context">
                <attribute name="type">object</attribute>
                <attribute name="example">
                    <attribute name="en_US">
                        <attribute name="uri">string</attribute>
                        <attribute name="metadataTitle">string</attribute>
                        <attribute name="metadataDescription">string</attribute>
                        <attribute name="openGraphMetadataTitle">string</attribute>
                        <attribute name="openGraphMetadataDescription">string</attribute>
                        <attribute name="openGraphMetadataUrl">string</attribute>
                        <attribute name="openGraphMetadataImage">string</attribute>
                        <attribute name="locale">string</attribute>
                    </attribute>
                </attribute>
            </attribute>
        </property>
        <property name="openGraphMetadataType" required="false" identifier="false" writable="true"/>
    </resource>
</resources>