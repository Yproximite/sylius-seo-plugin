<?xml version="1.0" encoding="UTF-8" ?>

<resources
    xmlns="https://api-platform.com/schema/metadata/resources-3.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://api-platform.com/schema/metadata/resources-3.0 https://api-platform.com/schema/metadata/resources-3.0.xsd"
>
    <resource class="%dedi_sylius_seo_plugin.model.seo_content.class%">
        <operations>
            <operation name="sylius_api_shop_seo_content_get_collection" class="ApiPlatform\Metadata\GetCollection"
                       uriTemplate="/shop/seo-contents">
                <filters>
                    <filter>dedi_sylius_seo_plugin.api.filter.uri</filter>
                    <filter>dedi_sylius_seo_plugin.api.filter.product_code</filter>
                    <filter>dedi_sylius_seo_plugin.api.filter.taxon_code</filter>
                    <filter>dedi_sylius_seo_plugin.api.filter.channel_code</filter>
                </filters>
                <normalizationContext>
                    <values>
                        <value name="groups">
                            <values>
                                <value>sylius:shop:seo_content:index</value>
                            </values>
                        </value>
                    </values>
                </normalizationContext>
            </operation>

            <operation name="sylius_api_shop_seo_content_get" class="ApiPlatform\Metadata\Get"
                       uriTemplate="/shop/seo-contents/{id}">
                <normalizationContext>
                    <values>
                        <value name="groups">
                            <values>
                                <value>sylius:shop:seo_content:show</value>
                            </values>
                        </value>
                    </values>
                </normalizationContext>
            </operation>

            <operation name="sylius_api_shop_seo_content_get_product_metadata"
                       class="ApiPlatform\Metadata\Get"
                       uriTemplate="/shop/seo-contents-for-product/{id}"
                       read="false"
                       controller="dedi_sylius_seo_plugin.api.controller.product_metadata"
            >
                <normalizationContext>
                    <values>
                        <value name="groups">
                            <values>
                                <value>sylius:shop:seo_content:show</value>
                            </values>
                        </value>
                    </values>
                </normalizationContext>
            </operation>

            <operation name="sylius_api_shop_seo_content_get_taxon_metadata"
                       class="ApiPlatform\Metadata\Get"
                       uriTemplate="/shop/seo-contents-for-taxon/{id}"
                       read="false"
                       controller="dedi_sylius_seo_plugin.api.controller.taxon_metadata"
            >
                <normalizationContext>
                    <values>
                        <value name="groups">
                            <values>
                                <value>sylius:shop:seo_content:show</value>
                            </values>
                        </value>
                    </values>
                </normalizationContext>
            </operation>
        </operations>
    </resource>
</resources>
